# ============================================
# DFeCentral - Variaveis de Ambiente
# ============================================
# Copie este arquivo para app.env e preencha os valores

# === APP ===
NODE_ENV=production
PORT=3003

# === DATABASE (PostgreSQL) ===
# Banco local na VM Oracle.
DATABASE_URL="postgresql://dfecentral:SENHA_AQUI@localhost:5432/dfecentral_db"

# === REDIS ===
REDIS_URL="redis://localhost:6380"

# === AUTH (NextAuth) ===
AUTH_SECRET="GERE_UM_SECRET_AQUI_com_openssl_rand_base64_32"
AUTH_URL="https://www.dfecentral.com.br"
WEB_BASE_URL="https://www.dfecentral.com.br"
APP_BASE_URL="https://www.dfecentral.com.br"
# URL publica da API. Necessaria para o callback do Google OAuth na VM Oracle.
API_PUBLIC_URL="https://api.dfecentral.com.br"

# === GOOGLE OAUTH ===
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# === API KEY (acesso interno + autenticação REST) ===
# Use uma chave forte e mantenha o mesmo valor no web/consulta quando eles precisarem chamar a API.
API_KEY="GERE_UMA_CHAVE_FORTE_AQUI"
# API_KEYS=""
# API_PROXY_KEY=""
API_BASE_URL="http://127.0.0.1:3004"

# === COBRANCA (InfinitePay) ===
INFINITEPAY_HANDLE="$maranata-software"

# === R2 / CLOUDFLARE STORAGE ===
R2_ACCOUNT_ID="SEU_ACCOUNT_ID_AQUI"
R2_ACCESS_KEY_ID="SUA_ACCESS_KEY_ID_AQUI"
R2_SECRET_ACCESS_KEY="SEU_SECRET_ACCESS_KEY_AQUI"
R2_BUCKET="xmldfecentral"
# R2_ENDPOINT="https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com"

# === API (Fastify) ===
LOG_LEVEL="info"
API_PORT=3004
API_HOST="127.0.0.1"
API_CORS_ORIGIN="https://www.dfecentral.com.br,https://consulta.dfecentral.com.br"

# === CONSULTA (Next.js portal publico) ===
CONSULTA_PORT=3005

# === SEFAZ ===
SEFAZ_AMBIENTE=1
# 1 = Producao, 2 = Homologacao

# === CERTIFICADO DIGITAL A1 ===
# Caminho absoluto para o arquivo PFX/P12 do certificado A1
# SEFAZ_CERT_PATH="/opt/apps/dfecentral/shared/certificados/seu-certificado.pfx"
# SEFAZ_CERT_PASS="senha_do_certificado"

# === SCRAPER ===
# Servico Playwright para consulta publica no portal SEFAZ
SCRAPER_URL="http://127.0.0.1:3100"

# === ANTI-CAPTACHA ===
# Chave para resolver reCAPTCHA do portal SEFAZ (https://anti-captcha.com)
# ANTICAPTCHA_KEY="sua_chave_aqui"

# === SMTP (Mailserver local) ===
# Se subir o Docker Mailserver na VM, a aplicação pode usar o submission local.
# Para envio externo, configure o relay do mailserver (OCI Email Delivery ou outro relay SMTP).
# Use as credenciais da caixa criada no DMS, por exemplo `contato@dfecentral.com.br`.
SMTP_HOST="127.0.0.1"
SMTP_PORT=587
SMTP_USER="contato@dfecentral.com.br"
# SMTP_PASS="senha_da_caixa_postal"
MAIL_FROM="contato@dfecentral.com.br"

# === CHAVES API ===
# API_KEY_SALT=""
