# ============================================
# DFeCentral - Variaveis de Ambiente
# ============================================
# Copie este arquivo para app.env e preencha os valores

# === APP ===
NODE_ENV=production
PORT=3003

# === DATABASE (PostgreSQL) ===
DATABASE_URL="postgresql://dfecentral:SENHA_AQUI@localhost:5432/dfecentral_db?schema=public"

# === REDIS ===
REDIS_URL="redis://localhost:6380"

# === AUTH (NextAuth) ===
AUTH_SECRET="GERE_UM_SECRET_AQUI_com_openssl_rand_base64_32"
AUTH_URL="https://www.dfecentral.com.br"

# === API (Fastify) ===
API_PORT=3004
API_HOST="127.0.0.1"
API_CORS_ORIGIN="https://www.dfecentral.com.br,https://consulta.dfecentral.com.br"

# === CONSULTA (Next.js portal publico) ===
CONSULTA_PORT=3005

# === SEFAZ ===
SEFAZ_AMBIENTE=2
# 1 = Producao, 2 = Homologacao

# === CERTIFICADO DIGITAL A1 ===
# Caminho absoluto para o arquivo PFX/P12 do certificado A1
# SEFAZ_CERT_PATH="/opt/apps/dfecentral/shared/certificados/seu-certificado.pfx"
# SEFAZ_CERT_PASS="senha_do_certificado"

# === SCRAPER ===
# Servico Playwright para consulta publica no portal SEFAZ
SCRAPER_URL="http://127.0.0.1:3100"

# === ANTI-CAPTACHA ===
# Chave para resolver reCAPTCHA do portal SEFAZ (https://anti-captcha.com)
# ANTICAPTCHA_KEY="sua_chave_aqui"

# === CHAVES API ===
# API_KEY_SALT=""
